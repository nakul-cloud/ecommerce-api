# Application Environment Config Example
ENV=development
ALLOWED_ORIGINS=*
APP_NAME="E-Commerce API"
APP_VERSION=1.0.0
DATABASE_PATH=data/ecommerce.db

# Security Config
SECRET_KEY=your-jwt-signing-secret-key-change-me
